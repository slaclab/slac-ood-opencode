---
cluster: '*'
form:
  - sif_version
  - llm_provider
  - slac_bedrock_key
  - sdf_sage_repo
  - sdf_sage_provider
  - cluster
  - working_dir
  - bc_num_hours
  - bc_email_on_started
attributes:
  llm_provider:
    widget: "select"
    label: "LLM Provider"
    help: " "
    options:
      - ["Bedrock (personal API key)", "bedrock"]
      - ["SDF-Sage (facility allocation)", "sdf_sage"]
  slac_bedrock_key:
    widget: "text_field"
    label: "SLAC AI API Key"
    help: |
      Request a [SLAC AI API Bedrock Key](https://slacprod.servicenowservices.com/it_services?id=sc_cat_item&sys_id=515f28711b607110c5d320eae54bcb64&sysparm_category=d65827c46fd921009c4235af1e3ee434).
    required: false
  sdf_sage_provider:
    widget: "select"
    label: "LLM Provider"
    help: |
      The routing backend within SDF-Sage. Use `copilot` unless told otherwise by your experiment's computing coordinator.
    options:
      - ["copilot", "copilot"]
      - ["s3df", "s3df"]
      - ["bedrock", "bedrock"]
  sdf_sage_repo:
    widget: "text_field"
    label: "Coact Repo"
    placeholder: "e.g. scs:default"
    help: |
      Your S3DF facility and repo allocation. Enter either:
      - `facility` — uses `facility:default` automatically
      - `facility:repo` — uses the specified repo

      Contact your experiment's computing coordinator if unsure of your facility or repo name.
      Authentication will happen automatically when the session starts.
  cluster:
    label: "Run on Cluster"
  sif_version:
    widget: "select"
    label: "OpenCode Version"
    help: |
      Version of OpenCode to run. Latest is recommended.
    options:
      <%
        sifs = Dir.glob("/sdf/sw/opencode/opencode_*.sif")
          .sort_by { |path| File.basename(path, '.sif').sub('opencode_', '').split('.').map(&:to_i) }
          .reverse
        sifs.each_with_index do |path, i|
          version = File.basename(path, '.sif').sub('opencode_', '')
          label = i == 0 ? "#{version} (latest)" : version
      %>
      - ["<%= label %>", "<%= path %>"]
      <% end %>
  working_dir:
    widget: "text_field"
    label: "Working Directory"
    value: ""
    placeholder: "$HOME (default)"
    help: |
      Directory where OpenCode will start. Leave blank for your home directory.
  bc_num_hours:
    widget: "number_field"
    label: "Session Duration (hours)"
    value: 8
    help: |
      How long to keep the session alive (max 168 hours).
    min: 1
    max: 168
    step: 1
